{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baplanner.local/contracts/planning-plan-calculate-v1.schema.json",
  "title": "planning.plan.calculate request and success response",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/response" }
  ],
  "$defs": {
    "request": {
      "allOf": [
        { "$ref": "protocol-envelope-v1.schema.json" },
        {
          "type": "object",
          "properties": {
            "protocol": { "const": 1 },
            "id": { "type": "string", "minLength": 1 },
            "type": { "const": "request" },
            "method": { "const": "planning.plan.calculate" },
            "payload": {
              "type": "object",
              "required": ["current_students", "plan"],
              "properties": {
                "current_students": {
                  "type": "array",
                  "items": { "$ref": "planning-types-v1.schema.json#/$defs/currentStudent" }
                },
                "plan": { "$ref": "planning-types-v1.schema.json#/$defs/growthPlan" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "response": {
      "allOf": [
        { "$ref": "protocol-envelope-v1.schema.json" },
        {
          "type": "object",
          "properties": {
            "protocol": { "const": 1 },
            "id": { "type": "string", "minLength": 1 },
            "type": { "const": "response" },
            "method": { "const": "planning.plan.calculate" },
            "payload": {
              "type": "object",
              "required": ["totals"],
              "properties": {
                "totals": { "$ref": "planning-types-v1.schema.json#/$defs/planCostSummary" }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  }
}
