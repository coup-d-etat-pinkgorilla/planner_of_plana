{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ba-planner.local/contracts/scanner-protocol-v1.schema.json",
  "title": "BA Planner scanner protocol v1",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/response" },
    { "$ref": "#/$defs/event" }
  ],
  "$defs": {
    "baseRequest": {
      "type": "object",
      "required": ["protocol", "id", "type", "method", "payload"],
      "properties": {
        "protocol": { "const": 1 },
        "id": { "type": "string", "minLength": 1 },
        "type": { "const": "request" },
        "method": { "type": "string", "pattern": "^scanner\\." },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },
    "baseResponse": {
      "type": "object",
      "required": ["protocol", "id", "type", "method", "payload"],
      "properties": {
        "protocol": { "const": 1 },
        "id": { "type": "string", "minLength": 1 },
        "type": { "const": "response" },
        "method": { "type": "string", "pattern": "^scanner\\." },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },
    "sessionRef": {
      "type": "object",
      "required": ["session_id", "generation"],
      "properties": {
        "session_id": { "type": "string", "minLength": 1 },
        "generation": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "fieldEvidence": {
      "type": "object",
      "required": ["field", "status", "source"],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "status": { "enum": ["ok", "inferred", "uncertain", "failed", "skipped", "region_missing"] },
        "source": { "type": "string", "minLength": 1 },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },
    "candidate": {
      "type": "object",
      "required": ["candidate_id", "session_id", "generation", "revision", "scan_kind", "payload", "evidence", "review_required", "approved", "audit"],
      "properties": {
        "candidate_id": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "generation": { "type": "integer", "minimum": 1 },
        "revision": { "type": "integer", "minimum": 1 },
        "scan_kind": { "enum": ["student", "inventory"] },
        "payload": { "type": "object" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/fieldEvidence" } },
        "review_required": { "type": "boolean" },
        "approved": { "type": "boolean" },
        "audit": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": false
    },
    "errorPayload": {
      "type": "object",
      "required": ["error"],
      "properties": {
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string" },
            "details": { "type": "object" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "request": {
      "allOf": [
        { "$ref": "#/$defs/baseRequest" },
        {
          "oneOf": [
            { "properties": { "method": { "const": "scanner.target.list" }, "payload": { "type": "object", "maxProperties": 0 } } },
            { "properties": { "method": { "const": "scanner.recognition.status" }, "payload": { "type": "object", "maxProperties": 0 } } },
            { "properties": { "method": { "const": "scanner.session.start" }, "payload": { "type": "object", "required": ["scan_kind", "target_id"], "properties": { "scan_kind": { "enum": ["student", "inventory"] }, "target_id": { "type": "string", "minLength": 1 } }, "additionalProperties": false } } },
            { "properties": { "method": { "const": "scanner.session.cancel" }, "payload": { "$ref": "#/$defs/sessionRef" } } },
            { "properties": { "method": { "const": "scanner.session.snapshot" }, "payload": { "$ref": "#/$defs/sessionRef" } } },
            { "properties": { "method": { "const": "scanner.candidate.get" }, "payload": { "type": "object", "required": ["session_id", "generation", "candidate_id"], "properties": { "session_id": { "type": "string", "minLength": 1 }, "generation": { "type": "integer", "minimum": 1 }, "candidate_id": { "type": "string", "minLength": 1 } }, "additionalProperties": false } } },
            { "properties": { "method": { "const": "scanner.candidate.review" }, "payload": { "type": "object", "required": ["session_id", "generation", "candidate_id", "expected_candidate_revision", "candidate_payload", "approve", "reason"], "properties": { "session_id": { "type": "string", "minLength": 1 }, "generation": { "type": "integer", "minimum": 1 }, "candidate_id": { "type": "string", "minLength": 1 }, "expected_candidate_revision": { "type": "integer", "minimum": 1 }, "candidate_payload": { "type": "object" }, "approve": { "type": "boolean" }, "reason": { "type": "string" } }, "additionalProperties": false } } },
            { "properties": { "method": { "const": "scanner.candidate.commit" }, "payload": { "type": "object", "required": ["session_id", "generation", "candidate_id", "candidate_revision", "profile_id", "expected_repository_revision", "idempotency_key"], "properties": { "session_id": { "type": "string", "minLength": 1 }, "generation": { "type": "integer", "minimum": 1 }, "candidate_id": { "type": "string", "minLength": 1 }, "candidate_revision": { "type": "integer", "minimum": 1 }, "profile_id": { "type": "string", "minLength": 1 }, "expected_repository_revision": { "type": "integer", "minimum": 0 }, "idempotency_key": { "type": "string", "minLength": 1 } }, "additionalProperties": false } } }
          ]
        }
      ]
    },
    "response": {
      "allOf": [
        { "$ref": "#/$defs/baseResponse" },
        {
          "oneOf": [
            { "properties": { "method": { "enum": ["scanner.target.list", "scanner.recognition.status", "scanner.session.start", "scanner.session.cancel", "scanner.session.snapshot", "scanner.candidate.get", "scanner.candidate.review", "scanner.candidate.commit"] }, "payload": { "$ref": "#/$defs/errorPayload" } } },
            {
              "properties": {
                "method": { "const": "scanner.target.list" },
                "payload": {
                  "type": "object",
                  "required": ["targets"],
                  "properties": {
                    "targets": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["target_id", "title", "status"],
                        "properties": {
                          "target_id": { "type": "string", "minLength": 1 },
                          "title": { "type": "string" },
                          "status": { "enum": ["ready", "minimized", "closed", "unsupported"] }
                        },
                        "additionalProperties": true
                      }
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            { "properties": { "method": { "const": "scanner.recognition.status" }, "payload": { "not": { "required": ["error"] } } } },
            { "properties": { "method": { "const": "scanner.session.start" }, "payload": { "type": "object", "required": ["session_id", "generation", "scan_kind"], "properties": { "session_id": { "type": "string", "minLength": 1 }, "generation": { "type": "integer", "minimum": 1 }, "scan_kind": { "enum": ["student", "inventory"] } }, "additionalProperties": false } } },
            { "properties": { "method": { "const": "scanner.session.cancel" }, "payload": { "not": { "required": ["error"] } } } },
            { "properties": { "method": { "const": "scanner.session.snapshot" }, "payload": { "not": { "required": ["error"] } } } },
            { "properties": { "method": { "const": "scanner.candidate.get" }, "payload": { "type": "object", "required": ["candidate"], "properties": { "candidate": { "$ref": "#/$defs/candidate" } }, "additionalProperties": false } } },
            { "properties": { "method": { "const": "scanner.candidate.review" }, "payload": { "type": "object", "required": ["candidate"], "properties": { "candidate": { "$ref": "#/$defs/candidate" } }, "additionalProperties": false } } },
            { "properties": { "method": { "const": "scanner.candidate.commit" }, "payload": { "not": { "required": ["error"] } } } }
          ]
        }
      ]
    },
    "event": {
      "type": "object",
      "required": ["protocol", "type", "method", "payload"],
      "properties": {
        "protocol": { "const": 1 },
        "type": { "const": "event" },
        "method": { "const": "scanner.session.event" },
        "payload": {
          "type": "object",
          "required": ["session_id", "generation", "sequence", "scan_kind", "event_kind"],
          "properties": {
            "session_id": { "type": "string", "minLength": 1 },
            "generation": { "type": "integer", "minimum": 1 },
            "sequence": { "type": "integer", "minimum": 1 },
            "scan_kind": { "enum": ["student", "inventory"] },
            "event_kind": { "enum": ["phase", "progress", "candidate", "diagnostic", "terminal"] },
            "phase": { "type": "string", "minLength": 1 },
            "current": { "type": "integer", "minimum": 0 },
            "total": { "type": ["integer", "null"], "minimum": 0 },
            "message_key": { "type": "string", "minLength": 1 },
            "candidate": { "$ref": "#/$defs/candidate" },
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string" },
            "outcome": { "enum": ["completed", "cancelled", "failed"] },
            "error": { "type": "object", "required": ["code", "message"], "properties": { "code": { "type": "string", "minLength": 1 }, "message": { "type": "string" } }, "additionalProperties": false }
          },
          "additionalProperties": false,
          "allOf": [
            { "if": { "properties": { "event_kind": { "const": "phase" } } }, "then": { "required": ["phase"] } },
            { "if": { "properties": { "event_kind": { "const": "progress" } } }, "then": { "required": ["current", "total", "message_key"] } },
            { "if": { "properties": { "event_kind": { "const": "candidate" } } }, "then": { "required": ["candidate"] } },
            { "if": { "properties": { "event_kind": { "const": "terminal" } } }, "then": { "required": ["outcome"] } }
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
