{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baplanner.local/contracts/repository-protocol-v1.schema.json",
  "title": "BA Planner repository protocol v1 requests",
  "oneOf": [
    {"$ref":"#/$defs/emptyRequest"},
    {"$ref":"#/$defs/createRequest"},
    {"$ref":"#/$defs/profileMutation"},
    {"$ref":"#/$defs/renameRequest"},
    {"$ref":"#/$defs/stateRequest"},
    {"$ref":"#/$defs/studentsRequest"},
    {"$ref":"#/$defs/inventoryRequest"},
    {"$ref":"#/$defs/goalsRequest"},
    {"$ref":"#/$defs/migrationRequest"},
    {"$ref":"#/$defs/response"}
  ],
  "$defs": {
    "base": {"type":"object","required":["protocol","id","type","method","payload"],"properties":{"protocol":{"const":1},"id":{"type":"string","minLength":1},"type":{"const":"request"},"method":{"type":"string"},"payload":{"type":"object"}},"additionalProperties":false},
    "response": {"allOf":[{"$ref":"#/$defs/responseBase"},{"oneOf":[{"properties":{"payload":{"$ref":"#/$defs/errorPayload"}}},{"properties":{"method":{"const":"repository.profile.list"},"payload":{"$ref":"#/$defs/listPayload"}}},{"properties":{"method":{"const":"repository.profile.create"},"payload":{"$ref":"#/$defs/createPayload"}}},{"properties":{"method":{"const":"repository.profile.current"},"payload":{"$ref":"#/$defs/currentPayload"}}},{"properties":{"method":{"enum":["repository.profile.select","repository.profile.rename","repository.students.update","repository.inventory.update","repository.goals.save"]},"payload":{"$ref":"#/$defs/revisionPayload"}}},{"properties":{"method":{"const":"repository.state.get"},"payload":{"$ref":"#/$defs/statePayload"}}}]}]},
    "error": {"type":"object","required":["code","message","retryable"],"properties":{"code":{"enum":["invalid_payload","profile_not_found","profile_name_conflict","revision_conflict","idempotency_conflict","repository_busy","corrupt_data","migration_required","migration_not_supported","persistence_failed","unknown_method"]},"message":{"type":"string","minLength":1},"retryable":{"type":"boolean"},"details":{"type":"object"}},"additionalProperties":false},
    "responseBase": {"type":"object","required":["protocol","id","type","method","payload"],"properties":{"protocol":{"const":1},"id":{"type":"string","minLength":1},"type":{"const":"response"},"method":{"enum":["repository.profile.list","repository.profile.create","repository.profile.current","repository.profile.select","repository.profile.rename","repository.state.get","repository.students.update","repository.inventory.update","repository.goals.save","repository.migration.preview"]},"payload":{"type":"object"}},"additionalProperties":false},
    "profileId": {"type":"string","pattern":"^[0-9a-f]{24}$"},
    "revision": {"type":"integer","minimum":0},
    "profileSummary": {"type":"object","required":["profile_id","display_name","revision","selected"],"properties":{"profile_id":{"$ref":"#/$defs/profileId"},"display_name":{"type":"string","minLength":1},"revision":{"$ref":"#/$defs/revision"},"selected":{"type":"boolean"}},"additionalProperties":false},
    "inventorySnapshot": {"type":"object","required":["version","entries"],"properties":{"version":{"const":1},"entries":{"type":"array","items":{"type":"object","required":["key","quantity"],"properties":{"key":{"type":"string","minLength":1},"quantity":{"type":["string","null"]},"item_id":{"type":["string","null"]},"name":{"type":["string","null"]},"index":{"type":["integer","null"]},"profile_id":{"type":["string","null"]}},"additionalProperties":false}}},"additionalProperties":false},
    "goalPlan": {"type":"object","required":["version","goals"],"properties":{"version":{"const":1},"goals":{"type":"array","items":{"type":"object","required":["student_id"],"properties":{"student_id":{"type":"string","minLength":1},"favorite":{"type":"boolean"},"notes":{"type":"string"}},"patternProperties":{"^target_(level|star|weapon_level|weapon_star|ex_skill|skill[123]|equip[123]_tier|equip[123]_level|equip4_tier|stat_(hp|atk|heal))$":{"type":["integer","null"],"minimum":0}},"additionalProperties":false}}},"additionalProperties":false},
    "confirmedStudent": {"type":"object","required":["version","student_id","values"],"properties":{"version":{"const":1},"student_id":{"type":"string","minLength":1},"values":{"type":"object"},"provenance":{"type":"object","additionalProperties":{"type":"string"}}},"additionalProperties":false},
    "errorPayload": {"type":"object","required":["error"],"properties":{"error":{"$ref":"#/$defs/error"}},"additionalProperties":false},
    "listPayload": {"type":"object","required":["profiles","selected_profile_id"],"properties":{"profiles":{"type":"array","items":{"$ref":"#/$defs/profileSummary"}},"selected_profile_id":{"oneOf":[{"$ref":"#/$defs/profileId"},{"type":"null"}]}},"additionalProperties":false},
    "createPayload": {"type":"object","required":["profile","revision"],"properties":{"profile":{"$ref":"#/$defs/profileSummary"},"revision":{"$ref":"#/$defs/revision"}},"additionalProperties":false},
    "currentPayload": {"type":"object","required":["profile"],"properties":{"profile":{"oneOf":[{"$ref":"#/$defs/profileSummary"},{"type":"null"}]}},"additionalProperties":false},
    "revisionPayload": {"type":"object","required":["revision"],"properties":{"revision":{"$ref":"#/$defs/revision"}},"additionalProperties":false},
    "statePayload": {"type":"object","required":["profile_id","revision","students","inventory","goals"],"properties":{"profile_id":{"$ref":"#/$defs/profileId"},"revision":{"$ref":"#/$defs/revision"},"students":{"type":"array","items":{"$ref":"#/$defs/confirmedStudent"}},"inventory":{"$ref":"#/$defs/inventorySnapshot"},"goals":{"$ref":"#/$defs/goalPlan"}},"additionalProperties":false},
    "emptyRequest": {"allOf":[{"$ref":"#/$defs/base"},{"properties":{"method":{"enum":["repository.profile.list","repository.profile.current"]},"payload":{"type":"object","maxProperties":0}}}]},
    "createRequest": {"allOf":[{"$ref":"#/$defs/base"},{"properties":{"method":{"const":"repository.profile.create"},"payload":{"$ref":"#/$defs/create"}}}]},
    "profileMutation": {"allOf":[{"$ref":"#/$defs/base"},{"properties":{"method":{"const":"repository.profile.select"},"payload":{"allOf":[{"$ref":"#/$defs/mutation"}],"unevaluatedProperties":false}}}]},
    "renameRequest": {"allOf":[{"$ref":"#/$defs/base"},{"properties":{"method":{"const":"repository.profile.rename"},"payload":{"allOf":[{"$ref":"#/$defs/mutation"},{"required":["display_name"],"properties":{"display_name":{"type":"string","minLength":1}}}],"unevaluatedProperties":false}}}]},
    "stateRequest": {"allOf":[{"$ref":"#/$defs/base"},{"properties":{"method":{"const":"repository.state.get"},"payload":{"type":"object","required":["profile_id"],"properties":{"profile_id":{"type":"string","minLength":1}},"additionalProperties":false}}}]},
    "studentsRequest": {"allOf":[{"$ref":"#/$defs/base"},{"properties":{"method":{"const":"repository.students.update"},"payload":{"allOf":[{"$ref":"#/$defs/mutation"},{"required":["students"],"properties":{"students":{"type":"array"}}}],"unevaluatedProperties":false}}}]},
    "inventoryRequest": {"allOf":[{"$ref":"#/$defs/base"},{"properties":{"method":{"const":"repository.inventory.update"},"payload":{"allOf":[{"$ref":"#/$defs/mutation"},{"required":["inventory"],"properties":{"inventory":{"type":"object"}}}],"unevaluatedProperties":false}}}]},
    "goalsRequest": {"allOf":[{"$ref":"#/$defs/base"},{"properties":{"method":{"const":"repository.goals.save"},"payload":{"allOf":[{"$ref":"#/$defs/mutation"},{"required":["goals"],"properties":{"goals":{"type":"object"}}}],"unevaluatedProperties":false}}}]},
    "migrationRequest": {"allOf":[{"$ref":"#/$defs/base"},{"properties":{"method":{"const":"repository.migration.preview"},"payload":{"type":"object","required":["source_path","profile_id"],"properties":{"source_path":{"type":"string","minLength":1},"profile_id":{"type":"string","minLength":1}},"additionalProperties":false}}}]},
    "create": {"type":"object","required":["display_name","idempotency_key"],"properties":{"display_name":{"type":"string","minLength":1},"idempotency_key":{"type":"string","minLength":1}},"additionalProperties":false},
    "mutation": {"type":"object","required":["profile_id","expected_revision","idempotency_key"],"properties":{"profile_id":{"type":"string","minLength":1},"expected_revision":{"type":"integer","minimum":0},"idempotency_key":{"type":"string","minLength":1}}}
  }
}
